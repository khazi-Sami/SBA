generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum QurbaniPaymentStatus {
  PAID
  PENDING
}

enum QurbaniMeatPreference {
  RECEIVE_MEAT
  DONATE
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  classesTaught      Class[]     @relation("TeacherClasses")
  recordingsUploaded Recording[] @relation("UserRecordings")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ClassStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Class {
  id              String      @id @default(cuid())
  title           String
  description     String?
  scheduledAt     DateTime
  durationMinutes Int         @default(60)
  meetLink        String
  status          ClassStatus @default(SCHEDULED)
  teacherId       String
  teacher         User        @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  recordings      Recording[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([teacherId])
  @@index([scheduledAt])
}

model Recording {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  description String?
  videoUrl    String
  thumbnailUrl String?
  createdById String
  createdBy   User     @relation("UserRecordings", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([classId])
  @@index([createdById])
}

model QurbaniSubmission {
  id              String                 @id @default(cuid())
  participantName String
  fatherName      String
  niyyahName      String
  contactNumber   String
  shares          Int
  totalAmount     Int
  paymentStatus   QurbaniPaymentStatus
  meatPreference  QurbaniMeatPreference
  createdAt       DateTime               @default(now())

  @@index([createdAt])
  @@index([paymentStatus])
}
